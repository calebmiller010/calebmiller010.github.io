---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const skills = [
  { group: "Languages", items: ["Python", "TypeScript", "Golang", "Java"] },
  { group: "Cloud — AWS", items: ["Lambda", "Glue", "S3", "EC2", "EKS", "SQS", "EventBridge", "IAM", "CloudFormation", "CDK", "Batch", "Lightsail", "Step Functions", "API Gateway", "Route 53"] },
  { group: "Infrastructure & DevOps", items: ["Terraform", "Docker", "Kubernetes", "Helm", "Git", "GitHub Actions", "Jenkins"] },
  { group: "Industry & Domain Standards", items: ["HL7 FHIR", "PCI Compliance"] },
  { group: "AI & Automation", items: ["LLM Integration", "Context Engineering", "Prompt Engineering", "Agentic Workflows", "Claude Code", "Google Gemini", "n8n (self-hosted)", "MCP (Model Context Protocol)", "Whisper", "Claude Skills", "AI-Augmented TDD"] },
  { group: "Backend & Architecture", items: ["RESTful API Design", "Event-Driven Architecture", "Microservices", "Serverless", "DSL Design", "Config-Driven Systems"] },
  { group: "Data & Storage", items: ["Snowflake", "Supabase", "PostgreSQL", "Pandas", "PySpark"] },
  { group: "Frontend & Deployment", items: ["Astro", "Vercel", "AppSmith"] },
  { group: "Testing & Quality", items: ["Behave", "Cucumber", "TDD", "Integration Testing", "Unit Testing"] },
];
---

<BaseLayout>
  <Nav />

  <main id="main">

    <!-- ── Hero ─────────────────────────────────────── -->
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__meta">
          <span class="tag tag--accent">Available for new roles</span>
        </div>
        <h1 class="hero__headline">
          Senior Engineer.<br />
          <span class="hero__accent">AI-Native.</span><br />
          Ships what matters.
        </h1>
        <p class="hero__sub">
          8+ years building cloud-native backend systems in fintech and healthcare.
          Lead architect of production AI pipelines and event-driven platforms at scale.
          I use AI as a force multiplier — delivering increased velocity without sacrificing quality.
        </p>
        <div class="hero__actions">
          <a href="mailto:calebmiller10@icloud.com" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Get in touch
          </a>
          <a href="https://github.com/calebmiller010" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>

        <!-- Stats strip -->
        <div class="hero__stats">
          <div class="stat">
            <span class="stat__num">8+</span>
            <span class="stat__label">Years shipping</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Work Highlight ────────────────────────────── -->
    <section class="section" id="work">
      <div class="container">
        <div class="section__header fade-in">
          <span class="tag">Day job</span>
          <h2 class="section__title">What I build at TrueAccord</h2>
        </div>

        <div class="work-card fade-in">
          <div class="work-card__header">
            <div>
              <p class="work-card__company">TrueAccord Corporation — TrueML Shared Services</p>
              <h3 class="work-card__role">Senior Software Engineer II</h3>
            </div>
            <span class="tag">2021 – Present</span>
          </div>

          <div class="work-card__kpi-strip">
            <div class="kpi">
              <span class="kpi__num">1 sprint</span>
              <span class="kpi__label">vs. 8-sprint estimate (60 pts)</span>
            </div>
            <div class="kpi__divider"></div>
            <div class="kpi">
              <span class="kpi__num">~$10M/yr</span>
              <span class="kpi__label">projected platform savings</span>
            </div>
            <div class="kpi__divider"></div>
            <div class="kpi">
              <span class="kpi__num">Weeks → hours</span>
              <span class="kpi__label">client onboarding time</span>
            </div>
          </div>

          <div class="work-card__story">
            <div class="story-group">
              <h4 class="story-group__title">Platform &amp; Engine</h4>
              <p class="story-group__text">
                Lead architect of <strong>TrueIntegrations</strong>, the company's most important platform initiative — a config-driven, event-driven integration layer standardizing ingestion of arbitrary client file formats into TrueAccord's internal data spec.
              </p>
              <p class="story-group__text">
                Solely designed and delivered the core <strong>Transformation Engine</strong> — a DSL-based Python engine (Pandas/PySpark) with intelligent Lambda/Glue routing. Estimated at 60 story points (~8 sprints for one engineer), I shipped it in <strong>one sprint</strong> using AI-augmented TDD. <em>TrueIntegrations is the only OTP team ahead of schedule company-wide.</em>
              </p>
            </div>

            <div class="story-group">
              <h4 class="story-group__title">Results</h4>
              <p class="story-group__text">
                Built an internal <strong>Claude AI Skill</strong> that auto-generates client onboarding config files from raw specs — compressing a weeks-long manual mapping process to a matter of hours.
              </p>
              <p class="story-group__text">
                Co-lead a 7-person senior engineering team alongside a Staff Engineer. Mentored multiple engineers through promotion cycles. Promoted SWE II → Senior → Senior II from 2021–2025.
              </p>
            </div>
          </div>

          <div class="work-card__tags">
            {["Python", "TypeScript", "Golang", "Java", "Cloud — AWS", "Terraform", "Docker", "Kubernetes", "Helm", "GitHub Actions", "Jenkins", "PCI Compliance", "AI & Automation", "Event-Driven Architecture", "Microservices", "DSL Design", "Config-Driven Systems", "Snowflake", "PostgreSQL", "Pandas", "PySpark", "Behave", "Test-Driven Development"].map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Projects ──────────────────────────────────── -->
    <section class="section" id="projects">
      <div class="container">
        <div class="section__header fade-in">
          <span class="tag">Side projects</span>
          <h2 class="section__title">Things I've shipped independently</h2>
        </div>

        <div class="projects-grid">
          {projects.map((project) => (
            <a
              href={`/projects/${project.id}`}
              class={`project-card fade-in ${project.data.featured ? 'project-card--featured' : ''}`}
            >
              <div class="project-card__header">
                <span class="tag tag--accent">{project.data.category}</span>
                <svg class="project-card__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
              <h3 class="project-card__title">{project.data.title}</h3>
              <p class="project-card__tagline">{project.data.tagline}</p>
              <p class="project-card__metric">{project.data.heroMetric}</p>
              <div class="project-card__progress">
                <div class="progress-bar" style={`--progress: ${project.data.progress}%`}></div>
                <span class="progress-label">{project.data.progress}% shipped</span>
              </div>
              <p class="project-card__url">{project.data.url.replace(/^https?:\/\//, '')}</p>
              <div class="project-card__tags">
                {project.data.tags.map((t: string) => <span class="tag">{t}</span>)}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Skills ────────────────────────────────────── -->
    <section class="section" id="about">
      <div class="container">
        <div class="section__header fade-in">
          <span class="tag">Toolkit</span>
          <h2 class="section__title">What I work with</h2>
        </div>
        <div class="skills-grid fade-in">
          {skills.map(group => (
            <div class="skill-group">
              <h3 class="skill-group__title">{group.group}</h3>
              <div class="skill-group__items">
                {group.items.map(item => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────── -->
    <section class="section section--cta">
      <div class="container">
        <div class="cta-block fade-in">
          <p class="cta-block__eyebrow">Open to new roles</p>
          <h2 class="cta-block__headline">Let's build something that matters.</h2>
          <p class="cta-block__body">
            I'm looking for Senior / Senior II engineering roles at companies where technical depth and AI leverage are valued.
            Remote-first. Target comp $180k+.
          </p>
          <div class="cta-block__actions">
            <a href="mailto:calebmiller10@icloud.com" class="btn btn--primary">
              calebmiller10@icloud.com
            </a>
            <a href="https://github.com/calebmiller010" target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
              GitHub ↗
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hero {
  padding-block: clamp(var(--space-16), 12vw, var(--space-32));
  border-bottom: 1px solid var(--color-border);
}
.hero__inner { display: flex; flex-direction: column; gap: var(--space-8); }
.hero__meta { display: flex; align-items: center; gap: var(--space-3); }
.hero__headline {
  font-family: var(--font-display);
  font-size: var(--text-hero);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 0.95;
  color: var(--color-text);
  max-width: 14ch;
}
.hero__accent { color: var(--color-accent); }
.hero__sub {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  max-width: 52ch;
  line-height: 1.6;
}
.hero__actions { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }

/* Stats strip */
.hero__stats {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-6);
  padding-top: var(--space-8);
  border-top: 1px solid var(--color-border);
  margin-top: var(--space-4);
}
.stat { display: flex; flex-direction: column; gap: var(--space-1); }
.stat__num {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 800;
  color: var(--color-text);
  line-height: 1;
}
.stat__label { font-size: var(--text-xs); color: var(--color-text-muted); max-width: 16ch; }
.stat__divider {
  width: 1px; height: 40px;
  background: var(--color-border);
  flex-shrink: 0;
}
@media (max-width: 640px) { .stat__divider { display: none; } }

/* ── Section shared ───────────────────────────────────── */
.section {
  padding-block: clamp(var(--space-12), 8vw, var(--space-24));
  border-bottom: 1px solid var(--color-border);
}
.section__header {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  margin-bottom: var(--space-10);
}
.section__title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

/* ── Work card ────────────────────────────────────────── */
.work-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: clamp(var(--space-6), 4vw, var(--space-10));
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  box-shadow: var(--shadow-sm);
}
.work-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-4);
}
.work-card__company {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 500;
  margin-bottom: var(--space-1);
  max-width: none;
}
.work-card__role {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--color-text);
}

/* KPI strip */
.work-card__kpi-strip {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-6);
  padding-block: var(--space-4);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.kpi {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}
.kpi__num {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--color-accent);
  line-height: 1.1;
}
.kpi__label { font-size: var(--text-xs); color: var(--color-text-muted); max-width: 18ch; }
.kpi__divider {
  width: 1px; height: 36px;
  background: var(--color-border);
  flex-shrink: 0;
}
@media (max-width: 520px) { .kpi__divider { display: none; } }

/* Story groups */
.work-card__story {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}
.story-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.story-group__title {
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-accent);
  margin-bottom: var(--space-1);
}
.story-group__text {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  line-height: 1.65;
  max-width: none;
}
.story-group__text strong { color: var(--color-text); font-weight: 600; }
.story-group__text em { color: var(--color-text-muted); font-style: italic; }

.work-card__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }

/* ── Projects grid ────────────────────────────────────── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
}
.project-card--featured {
  grid-column: span 1;
}
@media (max-width: 768px) {
  .projects-grid { grid-template-columns: 1fr; }
  .project-card--featured { grid-column: span 1; }
}
.project-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-6);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  text-decoration: none;
  color: inherit;
  transition: var(--transition);
  box-shadow: var(--shadow-sm);
}
.project-card:hover {
  border-color: var(--color-accent);
  box-shadow: var(--shadow-md), 0 0 0 1px var(--color-accent);
  transform: translateY(-2px);
}
.project-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.project-card__arrow {
  color: var(--color-text-faint);
  transition: color var(--transition), transform var(--transition);
}
.project-card:hover .project-card__arrow {
  color: var(--color-accent);
  transform: translate(2px, -2px);
}
.project-card__title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--color-text);
  line-height: 1.1;
}
.project-card__tagline {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.5;
  max-width: 44ch;
}
.project-card__metric {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-accent);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  max-width: none;
}
.project-card__progress {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}
.progress-bar {
  height: 4px;
  background: var(--color-surface-offset);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.progress-bar::before {
  content: '';
  display: block;
  height: 100%;
  width: var(--progress);
  background: var(--color-accent);
  border-radius: var(--radius-full);
  transition: width 600ms var(--ease-out-expo);
}
.progress-label {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
  font-weight: 500;
}
.project-card__url {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
  font-family: var(--font-body);
  letter-spacing: 0.01em;
  max-width: none;
  word-break: break-all;
}
.project-card:hover .project-card__url {
  color: var(--color-accent);
}
.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: auto;
}

/* ── Skills ───────────────────────────────────────────── */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--space-8);
}
.skill-group { display: flex; flex-direction: column; gap: var(--space-3); }
.skill-group__title {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-text);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-family: var(--font-body);
}
.skill-group__items { display: flex; flex-wrap: wrap; gap: var(--space-2); }

/* ── CTA ──────────────────────────────────────────────── */
.section--cta { border-bottom: none; }
.cta-block {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: clamp(var(--space-10), 6vw, var(--space-16));
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-6);
  box-shadow: var(--shadow-sm);
}
.cta-block__eyebrow {
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  max-width: none;
}
.cta-block__headline {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 900;
  letter-spacing: -0.025em;
  color: var(--color-text);
}
.cta-block__body {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  max-width: 46ch;
  line-height: 1.65;
}
.cta-block__actions {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
  justify-content: center;
}
</style>
